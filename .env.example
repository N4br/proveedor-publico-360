# API
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173

# Supabase server-side. Never expose SERVICE_ROLE to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_DOCUMENTS_BUCKET=company-documents
SUPABASE_STORAGE_TENDER_BUCKET=tender-documents

# Mercado Publico. Use the official ticket issued by ChileCompra in production.
# The value below is the public demo ticket commonly shown in ChileCompra API examples.
MERCADO_PUBLICO_TICKET=F8537A18-6766-4DEF-9E59-426B4FEE2844
MERCADO_PUBLICO_BASE_URL=https://api.mercadopublico.cl/servicios/v1/publico

# Optional experimental attachment extraction.
MERCADO_PUBLICO_ALLOW_HEADLESS_ATTACHMENTS=false
ATTACHMENTS_DOWNLOAD_DIR=attachments-test

# AI. Keep only on backend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_MODE=mock

# Frontend. In Vercel use same-origin API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_API_URL=/api
